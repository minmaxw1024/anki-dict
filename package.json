{
  "name": "anki-dict-extension",
  "version": "1.0.0",
  "description": "Browser extension for looking up English words and exporting to Anki (Chrome, Edge & Firefox)",
  "type": "module",
  "scripts": {
    "dev": "BROWSER=chrome vite build --watch --mode development",
    "dev:chrome": "BROWSER=chrome vite build --watch --mode development",
    "dev:firefox": "BROWSER=firefox vite build --watch --mode development",
    "build": "bun run build:chrome && bun run build:firefox && bun run build:edge",
    "build:chrome": "BROWSER=chrome tsc --noEmit && BROWSER=chrome vite build",
    "build:firefox": "BROWSER=firefox tsc --noEmit && BROWSER=firefox vite build",
    "build:edge": "BROWSER=edge tsc --noEmit && BROWSER=edge vite build",
    "pack": "bun run build && bun run pack:chrome && bun run pack:firefox && bun run pack:edge",
    "pack:chrome": "cd dist/chrome && zip -r ../anki-dict-chrome.zip .",
    "pack:firefox": "cd dist/firefox && zip -r ../anki-dict-firefox.zip .",
    "pack:edge": "cd dist/edge && zip -r ../anki-dict-edge.zip .",
    "type-check": "tsc --noEmit",
    "preview": "vite preview"
  },
  "keywords": [
    "chrome-extension",
    "firefox-extension",
    "anki",
    "dictionary",
    "cambridge",
    "vocabulary"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/webextension-polyfill": "^0.12.4",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  },
  "dependencies": {
    "webextension-polyfill": "^0.12.0"
  }
}
